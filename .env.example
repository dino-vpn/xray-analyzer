# ─── REQUIRED — Authentication & DB ─────────────────────────────────────────
# Сгенерируй сильные значения: openssl rand -hex 32

# Bearer token для /api/* endpoints. Если включён OIDC (см. ниже), браузерный
# вход идёт через PocketID, и API_TOKEN нужен только как опциональный сервисный
# токен для curl/скриптов — можно оставить пустым. Без OIDC это единственный
# способ входа в дашборд.
API_TOKEN=

# Bearer token для агентов (WebSocket /ws). Должен совпадать с AUTH_TOKEN в .env агента.
AGENT_TOKEN=

# Postgres password (используется analyzer-postgres контейнером)
POSTGRES_PASSWORD=


# ─── OIDC / SSO через PocketID (опционально, рекомендуется) ──────────────────
# Браузерный вход через PocketID вместо вставки API_TOKEN. Доступ получают
# только члены группы OIDC_ALLOWED_GROUP. После успешного входа сервер выдаёт
# собственный session-токен (HS256), который фронтенд хранит как и раньше.
#
# Настройка в PocketID: создай OIDC-клиент, redirect URI =
#   https://<твой-хост>/api/auth/callback
# включи scope "groups" и убедись, что нужная группа попадает в claim "groups".
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://id.example.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Публичный URL коллбэка (должен совпадать с redirect URI в PocketID).
OIDC_REDIRECT_URL=https://analyzer.example.com/api/auth/callback
# Только члены этой группы получают доступ (пусто = любой аутентифицированный).
OIDC_ALLOWED_GROUP=admins
# Claim с группами (PocketID по умолчанию "groups").
OIDC_GROUPS_CLAIM=groups
# Запрашиваемые scope'ы (через запятую).
OIDC_SCOPES=openid,profile,email,groups
# Ключ подписи session-токена: openssl rand -hex 32. Пусто = генерится случайно
# при старте (сессии не переживут рестарт сервера).
SESSION_SECRET=
# Время жизни session-токена (после истечения нужен повторный вход в 1 клик).
SESSION_TTL=12h


# ─── REQUIRED — Remnawave integration ───────────────────────────────────────
# Без этого дашборд работает в "log-only" режиме без username resolution.

REMNAWAVE_ENABLED=true
REMNAWAVE_URL=https://panel.example.com
REMNAWAVE_API_TOKEN=
# Интервал sync'а с panel API. 1m = свежие данные, нагрузка на panel минимальна.
REMNAWAVE_SYNC_INTERVAL=1m


# ─── CrowdSec (опционально) — централизованный бан IP юзера ──────────────────
# Для кнопки "Забанить IP" на вкладке Атаки. Использует ТОТ ЖЕ CrowdSec LAPI,
# что разворачивает ansible-репозиторий (crowd.devaleto.com). Добавление банов
# требует machine-credential (cscli machines add <id> --password <pw>), ключ
# bouncer'а для записи НЕ подходит. Также egress-IP этого сервера должен быть
# открыт в firewall на хосте crowdsec (см. ansible). Пусто = бан IP выключен.
CROWDSEC_ENABLED=false
CROWDSEC_URL=https://crowd.devaleto.com
CROWDSEC_MACHINE_ID=
CROWDSEC_PASSWORD=
# Пресет бана по умолчанию (30m/1h/3h/6h/12h/24h).
CROWDSEC_DEFAULT_BAN=30m


# ─── Node mapping (опционально, рекомендуется) ──────────────────────────────
# Связь agent NODE_ID с Remnawave node "name". Без этого онлайн-счётчики на
# дашборде будут падать обратно на access-log heuristic вместо XTLS.
# Формат: agent_id=Remnawave Name,agent_id2=Remnawave Name 2
# NODE_REMNA_MAP=germany-1=Germany 2,est-1=Estonia,poland-1=Poland


# ─── Telegram alerts (опционально) ──────────────────────────────────────────

TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# Роутинг по топикам форум-супергруппы (message_thread_id). Формат:
#   TELEGRAM_TOPICS=category=threadid,...
# Категории алертов:
#   threat    — threat-intel (malware/c2/phishing/botnet/ransomware/…)
#   blacklist — превышение лимита запросов к запрещённым доменам
#   scan      — порт-сканы / брут-форс (можно слать в один топик)
# Пример (порт-скан+брут в одну тему, threat-intel — в другую):
#   TELEGRAM_TOPICS=scan=2,threat=5,blacklist=8
# Пусто = все алерты в один чат без топиков.
TELEGRAM_TOPICS=
# Топик для алертов без явного маппинга и для тестового сообщения (0 = General).
TELEGRAM_DEFAULT_TOPIC=0


# ─── Threat detection thresholds ────────────────────────────────────────────
# Сколько запросов к threat-домену за окно для срабатывания алерта.

SUSPICIOUS_REQUEST_COUNT=5
SUSPICIOUS_TIME_WINDOW=1h


# ─── Blacklist (свой список доменов) ────────────────────────────────────────
# Локальный blacklist.txt в server/ грузится первым. Дополнительно можно указать
# URL на СВОЙ hosted-список доменов (по одному на строку, поддержка *.wildcard).
# ВНИМАНИЕ: не указывай сюда RU Re-filter list — там instagram/youtube/whatsapp
# и пр., которые для VPN являются обычными разрешёнными адресами и заспамят
# алерты. Пусто = только локальный blacklist.txt.
BLACKLIST_REMOTE_URL=
BLACKLIST_RELOAD=5m
BLACKLIST_PATH=./blacklist.txt


# ─── Threat-intel feeds ─────────────────────────────────────────────────────
# Внешние фиды угроз (malware/crypto/phishing/botnet из BlockList Project и др.).
# Если нужны только алерты по своему списку доменов — оставь false.
THREATINTEL_ENABLED=false


# ─── Server / runtime ───────────────────────────────────────────────────────

LISTEN_ADDR=:8237
# CORS origins для WS (JSON-style array, comma-separated). Пусто = allow all (dev mode).
ALLOWED_ORIGINS=


# ─── AI assistant (опционально, OpenAI-compatible) ──────────────────────────
# Встроенный AI-чат для запросов "найди abusers за час" и т.д. Работает с
# любым OpenAI-compatible /v1 endpoint:
#
#   • OpenAI:     OPENAI_BASE_URL=https://api.openai.com/v1
#                 OPENAI_MODEL=gpt-4o-mini
#   • Together:   OPENAI_BASE_URL=https://api.together.xyz/v1
#                 OPENAI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
#   • OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1
#                 OPENAI_MODEL=anthropic/claude-3.5-sonnet
#   • Local llama.cpp:  OPENAI_BASE_URL=http://localhost:8080/v1
#                       OPENAI_MODEL=local
#   • Aleria:     OPENAI_BASE_URL=https://aleria.com/_inference/v1
#                 OPENAI_MODEL=default
#
# Empty OPENAI_API_KEY = AI-чат выключен.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=


# ─── Web UI Mapbox token (опционально) ──────────────────────────────────────
# Без него карта geo-distribution показывает заглушку.
# Получить: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=


# ─── Redis (опционально, по умолчанию запускается analyzer-redis) ───────────
# REDIS_ADDR пустой = analyzer-redis из compose. Для внешнего Redis укажи host:port.
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_KEY_PREFIX=analyzer:
